{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "category", "date", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Spending budget for a category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "limit": { "type": "number" },
        "month": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "category", "limit", "month", "createdAt"]
    },
    "Goal": {
      "title": "Goal",
      "description": "Financial savings goal",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "number" },
        "color": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "targetAmount", "currentAmount", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User transaction history"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User budget settings"
    },
    "/users/{userId}/goals/{goalId}": {
      "schema": "Goal",
      "description": "User savings goals"
    }
  }
}
